# Supabase (service role for writing analysis results back to DB)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Path to stockfish binary (defaults to "stockfish" on PATH)
STOCKFISH_PATH=/usr/bin/stockfish

# Stockfish instance pool size (default 4)
STOCKFISH_POOL_SIZE=4
